<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Feroses vs Zombie: Pertahanan Taman</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- FontAwesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Fredoka+One&family=Quicksand:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Quicksand', sans-serif;
            background-color: #0b0f19;
            user-select: none;
            -webkit-user-select: none;
        }
        .font-game {
            font-family: 'Fredoka One', cursive;
        }
        
        /* Desain Rak Kayu Penyimpan Benih khas PvZ */
        .pvz-holder {
            background: linear-gradient(180deg, #854d0e 0%, #451a03 100%);
            border: 4px solid #b45309;
            box-shadow: inset 0 4px 6px rgba(0,0,0,0.6), 0 10px 15px -3px rgba(0,0,0,0.5);
        }

        /* Desain Kartu Paket Benih (Seed Packet) */
        .seed-packet {
            width: 80px;
            height: 105px;
            background: linear-gradient(180deg, #bfdbfe 0%, #3b82f6 100%);
            border: 3px solid #1e3a8a;
            border-radius: 6px;
            transition: all 0.15s ease-in-out;
            box-shadow: 0 4px 6px rgba(0,0,0,0.3);
        }
        .seed-packet:hover:not(:disabled) {
            transform: translateY(-4px);
            box-shadow: 0 10px 12px rgba(0,0,0,0.4);
            border-color: #fbbf24;
        }
        .seed-packet:disabled {
            filter: brightness(0.4) grayscale(0.3);
            cursor: not-allowed;
            transform: none;
        }
        .selected-seed {
            border-color: #f59e0b !important;
            box-shadow: 0 0 15px #f59e0b !important;
            transform: translateY(-6px) scale(1.02);
        }

        /* Sun Counter Plaque */
        .sun-plaque {
            background: #fef08a;
            border: 3px solid #ca8a04;
            box-shadow: inset 0 2px 4px rgba(0,0,0,0.3);
        }
    </style>
</head>
<body class="flex flex-col min-h-screen text-slate-100 overflow-x-hidden">

    <!-- HEADER STATUS GAME -->
    <header class="bg-slate-900 border-b-4 border-amber-800 p-4 sticky top-0 z-50 shadow-xl">
        <div class="max-w-6xl mx-auto flex flex-wrap items-center justify-between gap-4">
            <div class="flex items-center gap-3">
                <div class="bg-emerald-600 border-2 border-emerald-400 text-slate-950 p-2 rounded-xl shadow-lg">
                    <i class="fa-solid fa-seedling text-2xl text-white animate-bounce"></i>
                </div>
                <div>
                    <h1 class="font-game text-2xl tracking-wider text-emerald-400 drop-shadow-[0_2px_2px_rgba(0,0,0,0.8)]">FEROSES vs ZOMBIE</h1>
                    <p class="text-xs text-slate-400 font-bold">Edisi Spesial Pertahanan Taman Retro</p>
                </div>
            </div>
            
            <!-- Panel Ekonomi Klasik -->
            <div class="flex items-center gap-4 text-sm font-semibold">
                <!-- Counter Matahari Bulat Klasik -->

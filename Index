                </div>
            </div>

        </div>
    </main>

    <!-- FOOTER -->
    <footer class="bg-slate-900 border-t-4 border-amber-950 p-4 text-center text-xs text-slate-500 mt-auto">
        <p>&copy; 2026 Feroses vs Zombie - Grafis & Desain dioptimasi untuk nuansa klasik Plants vs Zombies.</p>
    </footer>

    <!-- LOGIKA JAVASCRIPT GAME -->
    <script>
        // DOM Elements
        const canvas = document.getElementById('gameCanvas');
        const ctx = canvas.getContext('2d');
        const startScreen = document.getElementById('start-screen');
        const gameContainer = document.getElementById('game-container');
        const sunCountEl = document.getElementById('sun-count');
        const waveCountEl = document.getElementById('wave-count');
        const scoreCountEl = document.getElementById('score-count');
        const gameOverModal = document.getElementById('game-over-modal');
        const victoryModal = document.getElementById('victory-modal');
        const victoryMsg = document.getElementById('victory-msg');
        const waveProgressBar = document.getElementById('wave-progress-bar');
        const flagIndicator = document.getElementById('flag-indicator');

        // Audio Synth untuk Efek Suara Klasik
        const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        function playSound(type) {
            try {
                if (audioCtx.state === 'suspended') {
                    audioCtx.resume();
                }
                const osc = audioCtx.createOscillator();
                const gain = audioCtx.createGain();
                osc.connect(gain);
                gain.connect(audioCtx.destination);

                if (type === 'plant') {
                    osc.type = 'sine';
                    osc.frequency.setValueAtTime(150, audioCtx.currentTime);
                    osc.frequency.exponentialRampToValueAtTime(300, audioCtx.currentTime + 0.15);
                    gain.gain.setValueAtTime(0.15, audioCtx.currentTime);
                    gain.gain.linearRampToValueAtTime(0.01, audioCtx.currentTime + 0.15);
                    osc.start();
                    osc.stop(audioCtx.currentTime + 0.15);
                } else if (type === 'sun') {
                    osc.type = 'triangle';
                    osc.frequency.setValueAtTime(523.25, audioCtx.currentTime); // C5
                    osc.frequency.setValueAtTime(659.25, audioCtx.currentTime + 0.08); // E5
                    osc.frequency.setValueAtTime(783.99, audioCtx.currentTime + 0.16); // G5
                    gain.gain.setValueAtTime(0.15, audioCtx.currentTime);
                    gain.gain.linearRampToValueAtTime(0.01, audioCtx.currentTime + 0.3);
                    osc.start();
                    osc.stop(audioCtx.currentTime + 0.3);
                } else if (type === 'shoot') {
                    osc.type = 'sine';
                    osc.frequency.setValueAtTime(220, audioCtx.currentTime);
                    osc.frequency.exponentialRampToValueAtTime(80, audioCtx.currentTime + 0.1);
                    gain.gain.setValueAtTime(0.08, audioCtx.currentTime);
                    gain.gain.linearRampToValueAtTime(0.01, audioCtx.currentTime + 0.1);
                    osc.start();
                    osc.stop(audioCtx.currentTime + 0.1);
                } else if (type === 'hit') {
                    osc.type = 'triangle';
                    osc.frequency.setValueAtTime(180, audioCtx.currentTime);
                    osc.frequency.exponentialRampToValueAtTime(50, audioCtx.currentTime + 0.08);
                    gain.gain.setValueAtTime(0.1, audioCtx.currentTime);
                    gain.gain.linearRampToValueAtTime(0.01, audioCtx.currentTime + 0.08);
                    osc.start();
                    osc.stop(audioCtx.currentTime + 0.08);
                } else if (type === 'mower') {
                    osc.type = 'sawtooth';
                    osc.frequency.setValueAtTime(100, audioCtx.currentTime);
                    osc.frequency.linearRampToValueAtTime(300, audioCtx.currentTime + 1.5);
                    gain.gain.setValueAtTime(0.12, audioCtx.currentTime);
                    gain.gain.linearRampToValueAtTime(0.01, audioCtx.currentTime + 1.5);
                    osc.start();
                    osc.stop(audioCtx.currentTime + 1.5);
                } else if (type === 'gameover') {
                    osc.type = 'sawtooth';
                    osc.frequency.setValueAtTime(300, audioCtx.currentTime);
                    osc.frequency.linearRampToValueAtTime(100, audioCtx.currentTime + 0.8);
                    gain.gain.setValueAtTime(0.2, audioCtx.currentTime);
                    gain.gain.linearRampToValueAtTime(0.01, audioCtx.currentTime + 0.8);
                    osc.start();
                    osc.stop(audioCtx.currentTime + 0.8);
                } else if (type === 'victory') {
                    osc.type = 'triangle';
                    osc.frequency.setValueAtTime(440, audioCtx.currentTime); // A4
                    osc.frequency.setValueAtTime(554, audioCtx.currentTime + 0.1); // C#5
                    osc.frequency.setValueAtTime(659, audioCtx.currentTime + 0.2); // E5
                    osc.frequency.setValueAtTime(880, audioCtx.currentTime + 0.3); // A5
                    gain.gain.setValueAtTime(0.2, audioCtx.currentTime);
                    gain.gain.linearRampToValueAtTime(0.01, audioCtx.currentTime + 0.6);
                    osc.start();
                    osc.stop(audioCtx.currentTime + 0.6);
                }
            } catch (e) {
                console.log("Audio API error:", e);
            }
        }

        // Grid Design & Configuration
        const gridRows = 5;
        const gridCols = 9;
        const colWidth = 85;
        const rowHeight = 85;
        
        // Pembagian area lapangan ala PvZ asli:
        const startX = 85;  // Sisi kiri: Teras halaman depan rumah (abu-abu semen)
        const startY = 60;  

        // Game Entities / State
        let suns = 150;
        let score = 0;
        let currentWave = 1;
        let maxWaveScore = 1500; // Skor target sebelum gelombang selesai
        let isGameRunning = false;
        let selectedPlantType = null;
        let selectedPlantCost = 0;
        let isShovelSelected = false;

        let plants = [];
        let zombies = [];
        let projectiles = [];
        let fallingSuns = [];
        let lawnMowers = [];
        let particles = [];

        // Game Loop / Timers
        let animationFrameId;
        let lastTime = 0;
        let zombieSpawnTimer = 0;
        let zombieSpawnInterval = 12000; 
        let naturalSunTimer = 0;
        const naturalSunInterval = 8000; 

        // Data statistik tanaman
        const plantStats = {
            sunferose: {
                name: "Sunferose",
                cost: 50,
                maxHp: 300,
                emoji: "🌻",
                actionCooldown: 12000, 
                color: "#fbbf24"
            },
            peaferose: {
                name: "Peaferose",
                cost: 100,
                maxHp: 300,
                emoji: "🌹",
                actionCooldown: 2000,  
                color: "#10b981"
            },
            wallferose: {
                name: "Wallferose",
                cost: 50,
                maxHp: 2800,           
                emoji: "🌵",
                actionCooldown: null,  
                color: "#d97706"
            },
            snowferose: {
                name: "Snowferose",
                cost: 175,
                maxHp: 300,
                emoji: "❄️",
                actionCooldown: 2200,  
                color: "#06b6d4"
            },
            // Baru: Spikeferose (Tombak Tanah)
            spikeferose: {
                name: "Spikeferose",
                cost: 100,
                maxHp: 600,
                emoji: "📌",
                actionCooldown: 800, // Menusuk zombie setiap 0.8 detik
                color: "#64748b"
            }
        };

        // Memilih tanaman dari kartu paket benih
        function selectPlantCard(type, cost) {
            if (suns < cost) return; 
            isShovelSelected = false;
            document.getElementById('btn-shovel').classList.remove('bg-yellow-500', 'text-slate-950');
            document.getElementById('btn-shovel').classList.add('bg-stone-800', 'text-slate-200');

            // Hapus seleksi kartu lain
            document.querySelectorAll('.seed-packet').forEach(el => el.classList.remove('selected-seed'));
            
            selectedPlantType = type;
            selectedPlantCost = cost;
            document.getElementById(`card-${type}`).classList.add('selected-seed');
        }

        // Mode sekop pembongkar
        function selectShovel() {
            selectedPlantType = null;
            selectedPlantCost = 0;
            document.querySelectorAll('.seed-packet').forEach(el => el.classList.remove('selected-seed'));

            isShovelSelected = !isShovelSelected;
            const btn = document.getElementById('btn-shovel');
            if (isShovelSelected) {
                btn.classList.add('bg-yellow-500', 'text-slate-950');
                btn.classList.remove('bg-stone-800', 'text-slate-200');
            } else {
                btn.classList.remove('bg-yellow-500', 'text-slate-950');
                btn.classList.add('bg-stone-800', 'text-slate-200');
            }
        }

        // Inisialisasi Mesin Pemotong Rumput Retro
        function initLawnMowers() {
            lawnMowers = [];
            for (let r = 0; r < gridRows; r++) {
                lawnMowers.push({
                    row: r,
                    x: startX - 55,
                    y: startY + r * rowHeight + 15,
                    w: 50,
                    h: 55,
                    state: 'idle', 
                    speed: 10
                });
            }
        }

        // Memulai permainan
        function startGame() {
            startScreen.classList.add('hidden');
            gameContainer.classList.remove('hidden');
            
            suns = 150;
            score = 0;
            currentWave = 1;
            maxWaveScore = currentWave * 1500;
            zombies = [];
            plants = [];
            projectiles = [];
            fallingSuns = [];
            particles = [];
            
            updateUI();
            initLawnMowers();

            gameOverModal.classList.add('opacity-0', 'pointer-events-none');
            victoryModal.classList.add('opacity-0', 'pointer-events-none');
            
            isGameRunning = true;
            zombieSpawnInterval = 12000;
            zombieSpawnTimer = 0;
            naturalSunTimer = 0;
            lastTime = performance.now();

            cancelAnimationFrame(animationFrameId);
            gameLoop(lastTime);
        }

        // Sinkronisasi Status UI & Efek Cooldown
        function updateUI() {
            sunCountEl.textContent = suns;
            waveCountEl.textContent = currentWave;
            scoreCountEl.textContent = score;

            // Update Progress Gelombang
            const progress = Math.min(100, (score / maxWaveScore) * 100);
            waveProgressBar.style.width = `${progress}%`;
            flagIndicator.style.right = `${100 - progress}%`;

            // Validasi paket benih
            Object.keys(plantStats).forEach(type => {
                const card = document.getElementById(`card-${type}`);
                const cooldownOverlay = document.getElementById(`cooldown-${type}`);
                if (card) {
                    if (suns < plantStats[type].cost) {
                        card.disabled = true;
                        cooldownOverlay.style.height = "100%"; // Gelapkan jika solar tidak cukup
                    } else {
                        card.disabled = false;
                        cooldownOverlay.style.height = "0%";
                    }
                }
            });
        }

        // Deteksi klik pada area Canvas
        canvas.addEventListener('click', (e) => {
            const rect = canvas.getBoundingClientRect();
            const clickX = e.clientX - rect.left;
            const clickY = e.clientY - rect.top;

            // 1. Ambil matahari jika diklik
            for (let i = fallingSuns.length - 1; i >= 0; i--) {
                const s = fallingSuns[i];
                const dist = Math.hypot(clickX - s.x, clickY - s.y);
                if (dist < 32) {
                    suns += s.amount;
                    playSound('sun');
                    createSparkleParticles(s.x, s.y, '#fbbf24');
                    fallingSuns.splice(i, 1);
                    updateUI();
                    return; 
                }
            }

            // 2. Terjemahkan klik ke petak taman rumput
            const col = Math.floor((clickX - startX) / colWidth);
            const row = Math.floor((clickY - startY) / rowHeight);

            if (row >= 0 && row < gridRows && col >= 0 && col < gridCols) {
                const existingPlantIndex = plants.findIndex(p => p.row === row && p.col === col);

                // Mode Sekop
                if (isShovelSelected) {
                    if (existingPlantIndex !== -1) {
                        createSparkleParticles(plants[existingPlantIndex].x, plants[existingPlantIndex].y, '#f43f5e');
                        plants.splice(existingPlantIndex, 1);
                        playSound('hit');
                        selectShovel(); 
                        updateUI();
                    }
                }
                // Mode Menanam
                else if (selectedPlantType) {
                    if (existingPlantIndex === -1 && suns >= selectedPlantCost) {
                        const plantX = startX + col * colWidth + colWidth / 2;
                        const plantY = startY + row * rowHeight + rowHeight / 2;

                        plants.push({
                            row: row,
                            col: col,
                            x: plantX,
                            y: plantY,
                            type: selectedPlantType,
                            hp: plantStats[selectedPlantType].maxHp,
                            maxHp: plantStats[selectedPlantType].maxHp,
                            lastAction: performance.now(),
                            cooldown: plantStats[selectedPlantType].actionCooldown,
                            spawnTime: performance.now()
                        });

                        suns -= selectedPlantCost;
                        playSound('plant');
                        createSparkleParticles(plantX, plantY, '#22c55e');

                        selectedPlantType = null;
                        selectedPlantCost = 0;
                        document.querySelectorAll('.seed-packet').forEach(el => el.classList.remove('selected-seed'));
                        updateUI();
                    }
                }
            }
        });

        // Partikel bintang gemerlap
        function createSparkleParticles(x, y, color) {
            for (let i = 0; i < 12; i++) {
                particles.push({
                    x: x,
                    y: y,
                    vx: (Math.random() - 0.5) * 5,
                    vy: (Math.random() - 0.5) * 5,
                    radius: Math.random() * 4 + 2,
                    alpha: 1,
                    decay: Math.random() * 0.04 + 0.02,
                    color: color
                });
            }
        }

        // Spawn Matahari dari langit
        function spawnNaturalSun() {
            const rx = Math.random() * (canvas.width - 250) + 120;
            const targetY = Math.random() * (canvas.height - 150) + 80;
            fallingSuns.push({
                x: rx,
                y: -30,
                targetY: targetY,
                amount: 25,
                timer: 0,
                isFloating: false
            });
        }

        // Spawn Zombie Baru
        function spawnZombie() {
            const randRow = Math.floor(Math.random() * gridRows);
            const py = startY + randRow * rowHeight + rowHeight / 2;

            const roll = Math.random() * 10;
            let type = "regular";
            let maxHp = 220 + currentWave * 40;
            let speed = 0.38 + Math.random() * 0.08;
            let emoji = "🧟";
            let color = "#4ade80";

            if (currentWave >= 2 && roll > 7) {
                type = "conehead"; // Zombie topi kerucut oranye
                maxHp = 480 + currentWave * 50;
                speed = 0.32;
                emoji = "🧟‍♂️";
                color = "#f97316"; 
            } else if (currentWave >= 3 && roll > 9) {
                type = "runner"; // Zombie cepat berbaju olahraga
                maxHp = 200 + currentWave * 30;
                speed = 0.8;
                emoji = "🏃‍♂️";
                color = "#ec4899";
            }

            zombies.push({
                row: randRow,
                x: canvas.width + 30,
                y: py,
                type: type,
                hp: maxHp,
                maxHp: maxHp,
                speed: speed,
                currentSpeed: speed,
                emoji: emoji,
                color: color,
                slowDuration: 0, 
                isEating: false,
                eatTimer: 0
            });
        }

        // Update Logika Game
        function updateGame(deltaTime) {
            naturalSunTimer += deltaTime;
            if (naturalSunTimer >= naturalSunInterval) {
                spawnNaturalSun();
                naturalSunTimer = 0;
            }

            zombieSpawnTimer += deltaTime;
            if (zombieSpawnTimer >= zombieSpawnInterval) {
                spawnZombie();
                zombieSpawnInterval = Math.max(3000, 12000 - currentWave * 900);
                zombieSpawnTimer = 0;
            }

            fallingSuns.forEach(s => {
                if (s.y < s.targetY) {
                    s.y += 1.8;
                } else {
                    s.isFloating = true;
                }
                s.timer += deltaTime;
            });

            fallingSuns = fallingSuns.filter(s => s.timer < 12000);

            const now = performance.now();
            
            // Logika Penyerangan Tanaman
            plants.forEach(p => {
                if (p.type === 'sunferose') {
                    if (now - p.lastAction > p.cooldown) {
                        fallingSuns.push({
                            x: p.x + (Math.random() - 0.5) * 50,
                            y: p.y - 15,
                            targetY: p.y + 20,
                            amount: 25,
                            timer: 0,
                            isFloating: false
                        });
                        p.lastAction = now;
                        createSparkleParticles(p.x, p.y, '#f59e0b');
                    }
                } else if (p.type === 'peaferose' || p.type === 'snowferose') {
                    const hasZombieInRow = zombies.some(z => z.row === p.row && z.x > p.x);
                    if (hasZombieInRow && now - p.lastAction > p.cooldown) {
                        projectiles.push({
                            row: p.row,
                            x: p.x + 22,
                            y: p.y - 10,
                            type: p.type === 'snowferose' ? 'ice' : 'normal',
                            speed: 6.5,
                            damage: p.type === 'snowferose' ? 22 : 20,
                            shootTime: now
                        });
                        p.lastAction = now;
                        playSound('shoot');
                    }
                } else if (p.type === 'spikeferose') {
                    // Logika Spikeferose: Menyerang zombie yang menginjak petak ubinnya secara berkala
                    zombies.forEach(z => {
                        if (z.row === p.row && Math.abs(z.x - p.x) < colWidth / 2) {
                            if (now - p.lastAction > p.cooldown) {
                                z.hp -= 25; // Damage tombak tajam
                                playSound('hit');
                                createSparkleParticles(z.x, z.y, '#94a3b8');
                                p.lastAction = now;
                            }
                        }
                    });
                }
            });

            // Gerakan Proyektil Duri
            for (let i = projectiles.length - 1; i >= 0; i--) {
                const proj = projectiles[i];
                proj.x += proj.speed;

                let hit = false;
                for (let j = 0; j < zombies.length; j++) {
                    const z = zombies[j];
                    if (z.row === proj.row && Math.abs(z.x - proj.x) < 25) {
                        z.hp -= proj.damage;
                        playSound('hit');
                        createSparkleParticles(proj.x, proj.y, proj.type === 'ice' ? '#22d3ee' : '#10b981');

                        if (proj.type === 'ice') {
                            z.slowDuration = 4500; 
                        }

                        hit = true;
                        break;
                    }
                }

                if (hit || proj.x > canvas.width) {
                    projectiles.splice(i, 1);
                }
            }

            // Gerakan Zombie & Gigitan Tanaman
            for (let i = zombies.length - 1; i >= 0; i--) {
                const z = zombies[i];

                if (z.slowDuration > 0) {
                    z.slowDuration -= deltaTime;
                    z.currentSpeed = z.speed * 0.45; 
                } else {
                    z.currentSpeed = z.speed;
                }

                let blocked = false;
                for (let j = 0; j < plants.length; j++) {
                    const p = plants[j];
                    // Zombie di baris yang sama, jarak dekat, DAN tanaman tersebut BUKAN spikeferose (karena tombak tanah tidak bisa dimakan/ditabrak)
                    if (p.row === z.row && Math.abs(p.x - z.x) < 32 && p.type !== 'spikeferose') {
                        blocked = true;
                        z.isEating = true;
                        z.eatTimer += deltaTime;
                        
                        // Kecepatan gigit zombie
                        p.hp -= 0.65; 

                        if (p.hp <= 0) {
                            createSparkleParticles(p.x, p.y, '#ef4444');
                            plants.splice(j, 1);
                            z.isEating = false;
                        }
                        break;
                    }
                }

                if (!blocked) {
                    z.isEating = false;
                    z.x -= z.currentSpeed;
                }

                if (z.hp <= 0) {
                    createSparkleParticles(z.x, z.y, '#22c55e');
                    score += z.type === 'conehead' ? 150 : (z.type === 'runner' ? 200 : 100);
                    updateUI();
                    zombies.splice(i, 1);
                    continue;
                }

                if (z.x < startX) {
                    const mower = lawnMowers.find(m => m.row === z.row);
                    if (mower && mower.state === 'idle') {
                        mower.state = 'moving';
                        playSound('mower');
                    } else if (!mower || mower.state === 'used') {
                        triggerGameOver();
                        return;
                    }
                }
            }

            // Sapu bersih oleh Mesin Pemotong
            lawnMowers.forEach(m => {
                if (m.state === 'moving') {
                    m.x += m.speed;

                    for (let i = zombies.length - 1; i >= 0; i--) {
                        const z = zombies[i];
                        if (z.row === m.row && z.x < m.x + 35 && z.x > m.x - 35) {
                            createSparkleParticles(z.x, z.y, '#f43f5e');
                            zombies.splice(i, 1);
                            score += 50;
                        }
                    }

                    if (m.x > canvas.width) {
                        m.state = 'used';
                    }
                }
            });

            // Syarat kemenangan gelombang
            if (score >= maxWaveScore && zombies.length === 0) {
                triggerVictory();
            }

            for (let i = particles.length - 1; i >= 0; i--) {
                const p = particles[i];
                p.x += p.vx;
                p.y += p.vy;
                p.alpha -= p.decay;
                if (p.alpha <= 0) {
                    particles.splice(i, 1);
                }
            }
        }

        // Gambar Visual ke Kanvas (Desain PvZ Klasik)
        function draw() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);

            // 1. BACKGROUND RUMPUT DAN TERAS PENGHUBUNG
            // Area Teras Depan Rumah (Semen Abu-abu)
            ctx.fillStyle = "#4b5563"; 
            ctx.fillRect(0, 0, startX, canvas.height);
            // Detail ubin semen teras
            ctx.strokeStyle = "#374151";
            ctx.lineWidth = 3;
            for (let y = startY; y < canvas.height; y += rowHeight) {
                ctx.beginPath();
                ctx.moveTo(0, y);
                ctx.lineTo(startX, y);
                ctx.stroke();
            }

            // Lapangan Rumput (Striped Green Lawn)
            for (let r = 0; r < gridRows; r++) {
                for (let c = 0; c < gridCols; c++) {
                    const cx = startX + c * colWidth;
                    const cy = startY + r * rowHeight;
                    
                    // Hijau bergaris berselang-seling khas PvZ
                    if ((r + c) % 2 === 0) {
                        ctx.fillStyle = "#38a169"; // Lighter Green
                    } else {
                        ctx.fillStyle = "#276749"; // Darker Green
                    }
                    ctx.fillRect(cx, cy, colWidth, rowHeight);

                    // Garis grid halus
                    ctx.strokeStyle = "rgba(0,0,0,0.12)";
                    ctx.lineWidth = 1;
                    ctx.strokeRect(cx, cy, colWidth, rowHeight);
                }
            }

            // Sisi Kanan: Area Tanah Berbatu Spawning Zombie
            const rightDirtStart = startX + gridCols * colWidth;
            ctx.fillStyle = "#78350f"; 
            ctx.fillRect(rightDirtStart, 0, canvas.width - rightDirtStart, canvas.height);

            // Pembatas Teras Rumah Merah Muda Tipis
            ctx.strokeStyle = "#e11d48";
            ctx.lineWidth = 4;
            ctx.beginPath();
            ctx.moveTo(startX, startY);
            ctx.lineTo(startX, startY + gridRows * rowHeight);
            ctx.stroke();

            // 2. GAMBAR MESIN PEMOTONG RUMPUT RETRO (Lawnmowers)
            lawnMowers.forEach(m => {
                if (m.state !== 'used') {
                    ctx.fillStyle = m.state === 'moving' ? '#ef4444' : '#dc2626';
                    ctx.beginPath();
                    ctx.roundRect(m.x, m.y, m.w, m.h, 12);
                    ctx.fill();

                    ctx.fillStyle = '#94a3b8';
                    ctx.fillRect(m.x + 8, m.y + 6, m.w - 16, 12);

                    ctx.fillStyle = '#1e293b';
                    ctx.beginPath();
                    ctx.arc(m.x + 12, m.y + m.h - 6, 8, 0, Math.PI * 2);
                    ctx.arc(m.x + m.w - 12, m.y + m.h - 6, 8, 0, Math.PI * 2);
                    ctx.fill();

                    ctx.fillStyle = '#ffffff';
                    ctx.font = "24px Arial";
                    ctx.textAlign = "center";
                    ctx.textBaseline = "middle";
                    const spinAngle = m.state === 'moving' ? (performance.now() * 0.05) : 0;
                    ctx.save();
                    ctx.translate(m.x + m.w / 2, m.y + m.h / 2);
                    ctx.rotate(spinAngle);
                    ctx.fillText("⚙️", 0, 0);
                    ctx.restore();
                }
            });

            // 3. GAMBAR MAWAR FEROSES (Plants)
            plants.forEach(p => {
                const stats = plantStats[p.type];

                // Bar HP jika tanaman sedang digigit zombie (Spikeferose tidak digigit)
                if (p.hp < p.maxHp && p.type !== 'spikeferose') {
                    const barW = 44;
                    const barH = 5;
                    ctx.fillStyle = 'rgba(0,0,0,0.6)';
                    ctx.fillRect(p.x - barW/2, p.y - 38, barW, barH);
                    const pct = Math.max(0, p.hp / p.maxHp);
                    ctx.fillStyle = pct > 0.5 ? '#22c55e' : (pct > 0.25 ? '#eab308' : '#ef4444');
                    ctx.fillRect(p.x - barW/2, p.y - 38, barW * pct, barH);
                }

                // Bayangan melingkar lembut di bawah kaki tanaman
                ctx.beginPath();
                ctx.arc(p.x, p.y + 24, 18, 0, Math.PI * 2);
                ctx.fillStyle = "rgba(0,0,0,0.3)";
                ctx.fill();

                // Custom Rendering khusus Spikeferose (Tombak Tanah)
                if (p.type === 'spikeferose') {
                    // Gambar duri/tombak tajam logam di tanah
                    ctx.save();
                    ctx.translate(p.x, p.y + 12);
                    ctx.font = "24px Arial";
                    ctx.textAlign = "center";
                    ctx.textBaseline = "middle";
                    
                    // Efek menusuk (goyang cepat naik turun)
                    const stabOffset = Math.sin(performance.now() * 0.02) * 2;
                    ctx.fillText("📌", -20, -10 + stabOffset);
                    ctx.fillText("📌", 0, -5 + stabOffset);
                    ctx.fillText("📌", 20, -10 + stabOffset);
                    ctx.restore();
                } else {
                    // Animasi pernapasan lentur tanaman mawar biasa
                    const breatheScale = 1 + Math.sin((performance.now() - p.spawnTime) * 0.004) * 0.04;
                    const swingAngle = Math.sin((performance.now() - p.spawnTime) * 0.003) * 0.05;

                    ctx.save();
                    ctx.translate(p.x, p.y + 12);
                    ctx.rotate(swingAngle);
                    ctx.scale(breatheScale, breatheScale);

                    // Tangkai tanaman hijau
                    ctx.fillStyle = "#16a34a";
                    ctx.fillRect(-4, -28, 8, 28);
                    
                    // Daun samping melengkung
                    ctx.beginPath();
                    ctx.ellipse(8, -12, 7, 3, Math.PI/4, 0, Math.PI*2);
                    ctx.ellipse(-8, -10, 7, 3, -Math.PI/4, 0, Math.PI*2);
                    ctx.fill();

                    // Kepala Tanaman
                    if (p.type === 'wallferose') {
                        ctx.font = "32px Arial";
                        ctx.textAlign = "center";
                        ctx.textBaseline = "middle";
                        if (p.hp < p.maxHp * 0.3) {
                            ctx.fillText("😢", 0, -28); 
                        } else if (p.hp < p.maxHp * 0.7) {
                            ctx.fillText("😐", 0, -28); 
                        } else {
                            ctx.fillText("🌵", 0, -28); 
                        }
                    } else {
                        ctx.font = "32px Arial";
                        ctx.textAlign = "center";
                        ctx.textBaseline = "middle";
                        ctx.fillText(stats.emoji, 0, -28);
                    }

                    ctx.restore();
                }
            });

            // 4. GAMBAR PROYEKTIL DURI MAWAR
            projectiles.forEach(proj => {
                const spin = (performance.now() - proj.shootTime) * 0.01;

                ctx.save();
                ctx.translate(proj.x, proj.y);
                ctx.rotate(spin);

                ctx.beginPath();
                ctx.arc(0, 0, 7, 0, Math.PI * 2);
                ctx.fillStyle = proj.type === 'ice' ? '#06b6d4' : '#ef4444';
                ctx.fill();

                ctx.beginPath();
                ctx.arc(-8, 0, 5, 0, Math.PI * 2);
                ctx.fillStyle = proj.type === 'ice' ? 'rgba(6, 182, 212, 0.4)' : 'rgba(239, 68, 68, 0.4)';
                ctx.fill();

                ctx.restore();
            });

            // 5. GAMBAR GEROMBOLAN ZOMBIE
            zombies.forEach(z => {
                ctx.beginPath();
                ctx.arc(z.x, z.y + 26, 18, 0, Math.PI * 2);
                ctx.fillStyle = "rgba(0,0,0,0.35)";
                ctx.fill();

                if (z.slowDuration > 0) {
                    ctx.beginPath();
                    ctx.arc(z.x, z.y + 26, 24, 0, Math.PI * 2);
                    ctx.strokeStyle = "#22d3ee";
                    ctx.lineWidth = 3;
                    ctx.stroke();
                }

                let walkY = Math.sin(performance.now() * 0.012 * z.currentSpeed + z.x) * 4.5;
                let headBob = 0;

                if (z.isEating) {
                    walkY = 0;
                    headBob = Math.sin(performance.now() * 0.035) * 3;
                }

                ctx.save();
                ctx.translate(z.x, z.y + walkY);

                ctx.fillStyle = "#78716c"; 
                ctx.fillRect(-8, -12, 16, 26);

                ctx.font = "36px Arial";
                ctx.textAlign = "center";
                ctx.textBaseline = "middle";
                ctx.fillText(z.emoji, 0, -18 + headBob);

                if (z.type === 'conehead') {
                    ctx.fillStyle = "#ea580c"; 
                    ctx.beginPath();
                    ctx.moveTo(0, -50 + headBob);
                    ctx.lineTo(-14, -30 + headBob);
                    ctx.lineTo(14, -30 + headBob);
                    ctx.closePath();
                    ctx.fill();

                    ctx.fillStyle = "#ffffff";
                    ctx.fillRect(-10, -36 + headBob, 20, 4);
                }

                ctx.restore();

                const barW = 34;
                const barH = 5;
                ctx.fillStyle = 'rgba(0,0,0,0.6)';
                ctx.fillRect(z.x - barW/2, z.y - 42, barW, barH);
                const pct = Math.max(0, z.hp / z.maxHp);
                ctx.fillStyle = '#ef4444';
                ctx.fillRect(z.x - barW/2, z.y - 42, barW * pct, barH);
            });

            // 6. GAMBAR MATAHARI BERPUTAR & BERSINAR (Suns)
            fallingSuns.forEach(s => {
                const rot = performance.now() * 0.0018;
                ctx.save();
                ctx.translate(s.x, s.y);
                ctx.rotate(rot);

                ctx.fillStyle = 'rgba(253, 224, 71, 0.28)';
                ctx.beginPath();
                ctx.arc(0, 0, 26, 0, Math.PI * 2);
                ctx.fill();

                ctx.font = "28px Arial";
                ctx.textAlign = "center";
                ctx.textBaseline = "middle";
                ctx.fillText("☀️", 0, 0);
                ctx.restore();
            });

            // 7. PARTIKEL PERCIKAN
            particles.forEach(p => {
                ctx.save();
                ctx.globalAlpha = p.alpha;
                ctx.fillStyle = p.color;
                ctx.beginPath();
                ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
                ctx.fill();
                ctx.restore();
            });
        }

        // Kalah
        function triggerGameOver() {
            isGameRunning = false;
            cancelAnimationFrame(animationFrameId);
            playSound('gameover');
            gameOverModal.classList.remove('opacity-0', 'pointer-events-none');
        }

        // Kemenangan Gelombang
        function triggerVictory() {
            isGameRunning = false;
            cancelAnimationFrame(animationFrameId);
            playSound('victory');
            victoryMsg.innerHTML = `Hebat! Halaman depan rumah berhasil disterilkan dari gerombolan zombie di <strong>Level ${currentWave}</strong>.<br>Bersiaplah untuk tantangan yang lebih masif!`;
            victoryModal.classList.remove('opacity-0', 'pointer-events-none');
        }

        // Lanjut Level
        function nextWave() {
            currentWave++;
            maxWaveScore = currentWave * 1500;
            suns += 150; 
            updateUI();
            
            zombies = [];
            projectiles = [];
            fallingSuns = [];
            
            victoryModal.classList.add('opacity-0', 'pointer-events-none');
            
            isGameRunning = true;
            zombieSpawnInterval = Math.max(3000, 12000 - currentWave * 900);
            zombieSpawnTimer = 0;
            naturalSunTimer = 0;
            lastTime = performance.now();
            
            gameLoop(lastTime);
        }

        function restartGame() {
            startGame();
        }

        function backToMenu() {
            isGameRunning = false;
            cancelAnimationFrame(animationFrameId);
            gameOverModal.classList.add('opacity-0', 'pointer-events-none');
            victoryModal.classList.add('opacity-0', 'pointer-events-none');
            gameContainer.classList.add('hidden');
            startScreen.classList.remove('hidden');
        }

        // Loop Game Utama
        function gameLoop(currentTime) {
            if (!isGameRunning) return;

            const deltaTime = currentTime - lastTime;
            lastTime = currentTime;

            updateGame(deltaTime);
            draw();

            animationFrameId = requestAnimationFrame(gameLoop);
        }
    </script>
</body>
</html>